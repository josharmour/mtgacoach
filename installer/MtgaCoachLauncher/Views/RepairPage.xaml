<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="MtgaCoachLauncher.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MtgaCoachLauncher.Views">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="12">
            <!-- Launch Options -->
            <TextBlock Text="Launch Options" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Restart Coach" Style="{StaticResource AccentButtonStyle}"
                        Click="RestartCoach_Click" />
                <Button Content="Restart as Autopilot" Click="RestartAutopilot_Click" />
                <CheckBox x:Name="DryRunCheck" Content="Dry-run" VerticalAlignment="Center" />
                <CheckBox x:Name="AfkCheck" Content="AFK" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Runtime Status -->
            <TextBlock Text="Runtime Status" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0" />
            <Grid x:Name="StatusGrid" RowSpacing="4" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            </Grid>
            <Button Content="Refresh Status" Click="Refresh_Click" />

            <!-- MTGA Location -->
            <TextBlock Text="MTGA Location" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="MtgaPathBox"
                         PlaceholderText="C:\Program Files\Wizards of the Coast\MTGA"
                         MinWidth="500" />
                <Button Content="Browse" Click="Browse_Click" />
                <Button Content="Save" Click="Save_Click" />
            </StackPanel>

            <!-- Update -->
            <TextBlock Text="Update" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnUpdate" Content="Check for Updates"
                        Style="{StaticResource AccentButtonStyle}" Click="CheckUpdate_Click" />
                <TextBlock x:Name="UpdateStatus" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Fix Everything -->
            <TextBlock Text="Fix Everything" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0" />
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="BtnFixAll" Content="Fix Everything"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="FixEverything_Click"
                            ToolTipService.ToolTip="Auto-detect and fix all issues: runtime, BepInEx, plugin, and version sync" />
                    <ProgressRing x:Name="FixProgress" IsActive="False"
                                  Width="20" Height="20" VerticalAlignment="Center" />
                    <TextBlock x:Name="FixStatus" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock x:Name="FixLog" TextWrapping="Wrap"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed" />
            </StackPanel>

            <!-- Individual Repairs -->
            <TextBlock Text="Individual Repairs" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Provision Runtime" Click="ProvisionRuntime_Click" />
                <Button Content="Repair MTGA Bridge" Click="RepairBridge_Click" />
                <Button Content="Install BepInEx" Click="InstallBepInEx_Click" />
                <Button Content="Install Plugin" Click="InstallPlugin_Click" />
            </StackPanel>

            <!-- Open Locations -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Open MTGA Folder" Click="OpenMtga_Click" />
                <Button Content="Open Player.log" Click="OpenPlayerLog_Click" />
                <Button Content="Open BepInEx Log" Click="OpenBepInExLog_Click" />
                <HyperlinkButton Content="GitHub Releases" Click="OpenReleases_Click" />
            </StackPanel>

            <!-- Log Tails -->
            <TextBlock Text="Log Tails" Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,8,0,0" />
            <TextBlock x:Name="LogTailText"
                       FontFamily="Consolas" FontSize="11"
                       TextWrapping="Wrap" IsTextSelectionEnabled="True"
                       MaxHeight="300"
                       Text="Loading..." />
            <Button Content="Refresh Logs" Click="RefreshLogs_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
