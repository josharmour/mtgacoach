# mtgacoach proxy server environment
# Copy to .env and fill in your values

# Admin dashboard password
ADMIN_PASSWORD=changeme

# AI Provider API Keys (enable providers by setting their keys)
# The proxy routes requests to the highest-priority available provider.

# Azure OpenAI (typically cheapest for high volume)
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT is set in config.yaml

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
