# mtgacoach Configuration
# Copy this file to .env and configure as needed

# License key for online mode (mtgacoach.com)
# Get yours at https://mtgacoach.com/subscribe
# Can also be set via the TUI with: /key YOUR_LICENSE_KEY
# MTGACOACH_LICENSE_KEY=

# Local model configuration (Ollama/LM Studio)
# These can also be set via the TUI with: /local
# LOCAL_URL=http://localhost:11434/v1
# LOCAL_MODEL=llama3.2

# Launcher maintenance
# Automatically trim Player.log before launch when MTGA is not already running.
ARENAMCP_TRIM_PLAYER_LOG=1
# Trim when Player.log exceeds this size in MB.
ARENAMCP_PLAYER_LOG_MAX_MB=64
# Keep the newest tail of Player.log at this size in MB.
ARENAMCP_PLAYER_LOG_KEEP_MB=8
